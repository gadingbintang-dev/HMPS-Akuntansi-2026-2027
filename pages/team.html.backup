    <script src="../js/script.js"></script>
    <script>
        // Fungsi toggle untuk division
        function toggleDivision(elementId) {
            const element = document.getElementById(elementId);
            const button = document.querySelector(`button[onclick="toggleDivision('${elementId}')"]`);
            const parentContainer = element.closest('.division-content-container');

            if(element) {
                if(element.classList.contains('hidden') || !element.classList.contains('active')) {
                    element.classList.remove('hidden');
                    element.classList.add('active');

                    if(button) {
                        button.classList.add('active');
                    }

                    // Periksa apakah ada dua divisi aktif dalam satu container
                    const activeDivisions = parentContainer.querySelectorAll('.division-single.active');
                    if(activeDivisions.length >= 2) {
                        parentContainer.classList.add('two-visible');
                    }
                } else {
                    element.classList.remove('active');
                    element.classList.add('hidden');

                    if(button) {
                        button.classList.remove('active');
                    }

                    // Periksa apakah masih ada dua divisi aktif
                    const activeDivisions = parentContainer.querySelectorAll('.division-single.active');
                    if(activeDivisions.length < 2) {
                        parentContainer.classList.remove('two-visible');
                    }
                }
            }
        }

        // Fungsi untuk menggulir ke atas halaman
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Fungsi untuk menampilkan/hide tombol scroll to top
        window.onscroll = function() {
            const scrollToTopBtn = document.getElementById('scrollToTopBtn');

            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                scrollToTopBtn.style.display = 'block';
            } else {
                scrollToTopBtn.style.display = 'none';
            }
        };

        // Setelah halaman dimuat, sembunyikan semua divisi
        document.addEventListener('DOMContentLoaded', function() {
            // Untuk setiap grup divisi, sembunyikan semua divisi secara default
            const divisionGroups = ['wadir1', 'wadir2', 'wadir3'];

            divisionGroups.forEach(group => {
                // Sembunyikan semua divisi dalam grup ini
                const allDivisions = document.querySelectorAll(`.division-content-container[data-parent="${group}"] .division-single`);
                allDivisions.forEach(division => {
                    division.classList.add('hidden');
                });

                // Hapus kelas active dari semua tombol
                const allButtons = document.querySelectorAll(`.division-buttons[data-parent="${group}"] button`);
                allButtons.forEach(button => {
                    button.classList.remove('active');
                });
            });
        });
    </script>

    <!-- Tombol Scroll to Top -->
    <button id="scrollToTopBtn" class="scroll-to-top-btn" onclick="scrollToTop()" title="Kembali ke atas">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- Tombol Navigasi Cepat -->
    <div class="quick-nav">
        <button class="nav-btn" onclick="scrollToSection('wadir1')" title="Wakil Direktur I">
            I
        </button>
        <button class="nav-btn" onclick="scrollToSection('wadir2')" title="Wakil Direktur II">
            II
        </button>
        <button class="nav-btn" onclick="scrollToSection('wadir3')" title="Wakil Direktur III">
            III
        </button>
    </div>

    <script>
        // Fungsi untuk menggulir ke bagian tertentu
        function scrollToSection(sectionId) {
            let element;
            switch(sectionId) {
                case 'wadir1':
                    element = document.getElementById('wadir1');
                    break;
                case 'wadir2':
                    element = document.getElementById('wadir2');
                    break;
                case 'wadir3':
                    element = document.getElementById('wadir3');
                    break;
            }

            if (element) {
                element.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    </script>
