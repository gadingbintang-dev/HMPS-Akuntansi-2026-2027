                            <div class="member-info">
                                <h4>Vina Okita</h4>
                                <p class="position">Wakil Direktur 1 HMPS Akuntansi</p>
                                <p class="bio">Bertanggung jawab atas bidang Pendidikan dan Riset dalam organisasi.</p>
                            </div>
                        </div>
                        
                        <div class="division-split-container">
                            <div class="division-buttons" data-parent="wadir1">
                                <button class="toggle-btn left-btn active" onclick="toggleDivision('division1-pendidikan')">Divisi Pendidikan</button>
                                <button class="toggle-btn right-btn" onclick="toggleDivision('division1-riset')">Divisi Riset</button>
                            </div>

                            <div class="division-content-container" data-parent="wadir1">
                                <div id="division1-pendidikan" class="division-single active">
